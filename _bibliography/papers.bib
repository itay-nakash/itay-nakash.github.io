      year={2025},
      url={https://openreview.net/forum?id=TyXf9dwpZP},
      bibtex_show={true},
      eprint={2503.19693},
      selected={true},
      abbr = {COLM 2025},
      arxiv={2503.19693},
      archivePrefix={arXiv},
      primaryClass={cs.CL},
      abstract={AdaptiVocab improves domain-specific LLM efficiency by replacing underused vocabulary items with domain n-gram tokens and initializing their embeddings from existing tokens. Across niche domains and two 7B models, it cuts input and output token usage by more than 25 percent while preserving generation quality and downstream performance.},
